{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "agents/*.md",
    "usage-rules.md"
  ],
  "plugin": ["@tarquinen/opencode-dcp@latest"],
  "agent": {
    "build": { "disable": true },
    "latex-writer": { "disable": true },
    "plan": { "disable": true },
    "yapper": { "disable": true }
  },
  "lsp": { "elixir": {"disabled": true} },
  "mcp": {
    "graphite": {
      "type": "local",
      "enabled": true,
      "command": [
        "gt",
        "mcp"
      ]
    },
    "morph-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@morphllm/morphmcp"],
      "environment": {
        "MORPH_API_KEY": "{env:MORPH_API_KEY}",
        "ENABLED_TOOLS": "edit_file,warpgrep_codebase_search"
      }
    },
    "tidewave": {
      "type": "local",
      "enabled": true,
      "command": [
        "mcp-proxy-wrapper",
        "TIDEWAVE_MCP_ENDPOINT"
      ]
    }
  }
}
